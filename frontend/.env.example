# frontend/.env.example
# Copie ce fichier en ".env" et remplace l'IP par celle de Ndeye Maty

# En développement (IP locale de Ndeye Maty sur le même réseau WiFi)
VITE_API_URL=http://192.168.1.XX/sdp_api

# En production (après déploiement sur Hostinger)
# VITE_API_URL=https://votre-domaine.com/sdp_api
